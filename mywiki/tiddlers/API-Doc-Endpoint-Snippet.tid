!! 2. 스키마 토글 (응답/요청 스키마 보여줄 때)

<pre>
&lt;$reveal state="$_:/state/schema-SCHEMA-ID" type="match" text="yes" default="no" tag="div"&gt;
&lt;$button class="api-schema-link" set="$_:/state/schema-SCHEMA-ID" setTo="no"&gt;→ SchemaName ▾&lt;/$button&gt;
&lt;/$reveal&gt;
&lt;$reveal state="$_:/state/schema-SCHEMA-ID" type="nomatch" text="yes" default="no" tag="div"&gt;
&lt;$button class="api-schema-link" set="$_:/state/schema-SCHEMA-ID" setTo="yes"&gt;→ SchemaName ▸&lt;/$button&gt;
&lt;/$reveal&gt;
&lt;$reveal state="$_:/state/schema-SCHEMA-ID" type="match" text="yes" default="no" class="api-schema-body" tag="div"&gt;
&lt;pre&gt;&lt;code&gt;{
  "field": "type"
}&lt;/code&gt;&lt;/pre&gt;
&lt;/$reveal&gt;
</pre>

